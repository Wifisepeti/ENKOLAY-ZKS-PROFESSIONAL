{
  "name": "enkolay-zks-professional",
  "productName": "ENKOLAY ZKS Professional",
  "version": "1.0.0",
  "description": "ENKOLAY ZKS Professional - Profesyonel Ziyaretçi Kayıt Sistemi",
  "author": "ENKOLAY Bilişim",
  "license": "Commercial",

  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },

  "dependencies": {
    "better-sqlite3": "^12.4.1"
  },

  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12",
    "@electron/rebuild": "^3.7.2"
  },

  "build": {
    "appId": "com.enkolay.zks",

    "productName": "ENKOLAY ZKS Professional",

    "asar": true,

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*",
      "!backup/*",
      "!node_modules/.cache/**/*"
    ],

    "extraResources": [
      {
        "from": "database",
        "to": "database"
      },
      {
        "from": "backup",
        "to": "backup"
      }
    ],

    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ENKOLAY ZKS Professional"
    }
  }
}